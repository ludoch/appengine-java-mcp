# App Engine Java MCP Server – environment variable reference
# Copy to .env for local development (dotenv-java loads it automatically).
# On App Engine, set these via appengine-web.xml <env-variables> or:
#   gcloud app deploy --set-env-vars KEY=VALUE

# ─── Core configuration ───────────────────────────────────────────────────────

# Force stdio mode even on GCP (set to "false" to always use HTTP/SSE mode)
# GCP_STDIO=true

# Default GCP project ID (used as default in tool calls)
# GOOGLE_CLOUD_PROJECT=my-project-id

# Default App Engine service name
DEFAULT_SERVICE_NAME=default

# Skip App Engine IAM invoker check (set to false in production to require auth)
SKIP_IAM_CHECK=true

# HTTP port for local embedded Jetty server
PORT=8080

# ─── Memcache / caching ───────────────────────────────────────────────────────

# Seconds to cache GCP API responses in App Engine Memcache (0 = disable)
CACHE_TTL_SECONDS=120

# ─── OAuth configuration (optional) ──────────────────────────────────────────
# Leave unset to use Application Default Credentials (gcloud auth application-default login)

# Set to "true" to enable OAuth token validation on /mcp, /sse, /messages
# OAUTH_ENABLED=true

# Google OAuth client credentials (from Google Cloud Console)
# GOOGLE_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
# GOOGLE_OAUTH_CLIENT_SECRET=your-client-secret

# OAuth audience (usually equals GOOGLE_OAUTH_CLIENT_ID)
# GOOGLE_OAUTH_AUDIENCE=your-client-id.apps.googleusercontent.com

# URLs for the OAuth well-known endpoints
# OAUTH_PROTECTED_RESOURCE=https://your-app.appspot.com/mcp
# OAUTH_AUTHORIZATION_SERVER=https://your-app.appspot.com/.well-known/oauth-authorization-server
# OAUTH_AUTHORIZATION_ENDPOINT=https://accounts.google.com/o/oauth2/v2/auth
# OAUTH_TOKEN_ENDPOINT=https://oauth2.googleapis.com/token
